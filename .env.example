# Server
PORT=3000
DATABASE_PATH=./data/seo-engine.db
SETUP_SECRET=change-me-to-a-random-string
CORS_ORIGIN=*

# Knowledge base (path to .md files)
KB_PATH=./knowledge

# Google Search Console (service account)
GSC_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
GSC_SITE_URL=https://crmchat.com

# Claude (article generation + grounding)
ANTHROPIC_API_KEY=sk-ant-...

# DALL-E (thumbnail generation - optional, articles work without)
OPENAI_API_KEY=sk-...

# Cloudflare R2 (asset storage - optional, articles work without)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=seo-engine-assets

# Screenshot API (optional - screenshotone.com)
SCREENSHOT_API_KEY=

# Slack notifications (optional)
SLACK_WEBHOOK_URL=
